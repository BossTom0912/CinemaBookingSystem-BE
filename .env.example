# Copy this file to .env, then replace every REPLACE_* value locally.
# .env is ignored by Git. Never put real secrets in Dockerfile, compose, or appsettings examples.

# Docker Desktop resolves this name to the Windows host, where your existing SQL Server runs.
# Use the actual TCP port for your SQL Server instance (often 1433).
ConnectionStrings__DefaultConnection=Server=host.docker.internal,1433;Database=CinemaBookingDB;User Id=sa;Password=REPLACE_SQL_PASSWORD;TrustServerCertificate=True;Encrypt=False

JwtSettings__Issuer=CinemaSystem
JwtSettings__Audience=CinemaSystem.Api
JwtSettings__Secret=REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
JwtSettings__AccessTokenMinutes=15
JwtSettings__RefreshTokenDays=7
JwtSettings__ClockSkewSeconds=60
SecuritySettings__ConfirmationTokenSecret=REPLACE_WITH_A_SECOND_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS

# Keep mock email enabled until SMTP has been configured deliberately.
EmailSettings__UseMock=true
EmailSettings__AutoConfirmEmail=false

# Add the public FE ngrok origin when the FE is exposed. No trailing slash.
CorsSettings__AllowedOrigins__0=http://localhost:5173
CorsSettings__AllowedOrigins__1=http://127.0.0.1:5173
CorsSettings__AllowedOrigins__2=https://REPLACE_WITH_FE_NGROK_HOST.ngrok-free.app

TicketScanSettings__OpenBeforeStartMinutes=30
TicketScanSettings__CloseAfterEndMinutes=0
SepaySettings__WebhookSecret=REPLACE_WITH_SEPAY_WEBHOOK_SECRET
RefundSettings__FrontendBaseUrl=http://localhost:5173
RefundSettings__ClaimTokenMinutes=5
